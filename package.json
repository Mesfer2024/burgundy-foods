{
  "name": "burgundy-foods",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate && node --no-warnings prisma/setup-local-db.mjs && prisma db seed",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:generate": "prisma generate",
    "db:push": "node --no-warnings prisma/setup-local-db.mjs",
    "db:seed": "prisma db seed",
    "setup:local": "prisma generate && node --no-warnings prisma/setup-local-db.mjs && prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.13.0",
    "bcrypt": "^6.0.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "prisma": "^5.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
