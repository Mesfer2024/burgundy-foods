# Local development env vars — copy to .env and fill in values
# Production env vars are set in the Vercel project settings, not here.

# ---- Database ----
# Local default: SQLite file. Production: a hosted Postgres connection string.
# Examples:
#   Neon:     postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   Supabase: postgres://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres
#   Vercel Postgres: copy from Storage tab in the Vercel dashboard
DATABASE_URL="file:./dev.db"

# ---- NextAuth ----
# In production set NEXTAUTH_URL to the deployed domain.
NEXTAUTH_URL="http://127.0.0.1:3100"
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace_this_with_a_secure_random_value"

# ---- Admin seed (required) ----
# `npm run db:seed` (and `prisma db seed`) creates the first admin user from these
# values. Both must be set or the seed exits with an error.
# In production, set a strong password here, run the seed once against the
# production DB, then change the password from the dashboard UI.
SEED_ADMIN_EMAIL="admin@burgundy-foods.com"
SEED_ADMIN_PASSWORD="replace_this_with_a_strong_password"
