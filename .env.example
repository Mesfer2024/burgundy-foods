# إعداد متغيرات البيئة المحلية للمشروع
# Local development env vars — copy to .env and fill in values

DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://127.0.0.1:3100"
NEXTAUTH_SECRET="replace_this_with_a_secure_random_value"

# Admin user created by `npm run db:seed`. Required — seed will refuse to run if missing.
# Use a strong password for any non-local environment.
SEED_ADMIN_EMAIL="admin@burgundy-foods.com"
SEED_ADMIN_PASSWORD="replace_this_with_a_strong_password"

# للإنتاج (Vercel) — بدّل datasource في prisma/schema.prisma إلى PostgreSQL وضع DATABASE_URL لخادم منتج.
# اضبط NEXTAUTH_URL على نطاق الإنتاج (مثل https://www.burgundy-foods.com) واستخدم NEXTAUTH_SECRET عشوائي.
# يمكن إضافة متغيرات إضافية لاحقاً مثل مزود الفوترة الإلكترونية أو مفاتيح API.
